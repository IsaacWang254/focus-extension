{
  "manifest_version": 3,
  "name": "Focus Extension",
  "version": "1.0.0",
  "description": "Block distracting websites and display your Todoist todos instead. Stay focused and productive.",
  "incognito": "split",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "identity",
    "tabs",
    "alarms",
    "history",
    "notifications"
  ],
  "optional_permissions": [
    "identity.email"
  ],
  "oauth2": {
    "client_id": "__GOOGLE_OAUTH_CLIENT_ID__",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.readonly",
      "https://www.googleapis.com/auth/calendar.events.readonly"
    ]
  },
  "host_permissions": [
    "*://*/*",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.x.com/*", "*://x.com/*"],
      "js": ["content-redirect.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "blocked/blocked.html",
        "blocked/blocked.css",
        "blocked/blocked.js",
        "lib/todoist.js",
        "lib/icons.js",
        "lib/common.css",
        "stats/stats.html",
        "stats/stats.css",
        "stats/stats.js",
        "newtab/newtab.html",
        "newtab/newtab.css",
        "newtab/newtab.js",
        "newtab/quotes.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
